function t.UpdateSelected() --[[ UpdateSelected | Line: 4572 | Upvalues: Data (copy), t (copy), CommonFunctions (copy), CurrencyTypes (copy), LethalNum (copy) ]]
    local world = Data.ImportantData.Stats.world
    local v1 = if world == 1 then Data.ImportantData.Misc.player.PlayerGui:WaitForChild("W1").SingularityChart.ShopContainer else nil

    if world == 2 then
        v1 = Data.ImportantData.Misc.player.PlayerGui:WaitForChild("W2").TempleUpgrades.ShopContainer
    end

    if not v1 then
        print("no menu")

        return
    end

    if world == 1 and Data.ImportantData.Stats.solChal ~= "none" then
        v1.Info.Title.Text = "<b>Closed</b>"
        v1.Info.Info.Text = "<b>You cannot buy upgrades inside of a challenge</b>"
        v1.Info.Buy.Visible = false

        return
    end

    if Data.ImportantData.Stats.unlockSelected == "none" then
        v1.Info.Title.Text = "<b>Select something</b>"
        v1.Info.Info.Text = ""
        v1.Info.Buy.Visible = false

        return
    end

    local v2 = t.Upgrades[Data.ImportantData.Stats.unlockSelected]

    if v2.levelCap > 1 then
        v1.Info.Title.Text = "<b>" .. v2.displayName .. " (" .. v2.level .. "/" .. v2.levelCap .. ")</b>"
    else
        v1.Info.Title.Text = "<b>" .. v2.displayName .. "</b>"
    end

    if not (v2.level >= v2.levelCap) then
        v1.Info.Info.Text = "<b>" .. v2.desc .. "\n\nCost: " .. CommonFunctions.canAffordText(CurrencyTypes.GetCurrencyAmt(v2.res), v2.cost) .. LethalNum.getString(v2.cost) .. " " .. CurrencyTypes.GetCurrencyDisplay(v2.res, v2.cost) .. " (Owned: " .. LethalNum.getString(CurrencyTypes.GetCurrencyAmt(v2.res)) .. ")</font></b>"
        v1.Info.Buy.Visible = true

        return
    end

    if v2.levelCap > 1 then
        v1.Info.Info.Text = "<b>" .. v2.desc .. "\n\n<font color=\"#ff00ff\">Maxed!</font></b>"
    else
        v1.Info.Info.Text = "<b>" .. v2.desc .. "\n\n<font color=\"#ff00ff\">Unlocked!</font></b>"
    end

    v1.Info.Buy.Visible = false
end
