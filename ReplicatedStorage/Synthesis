    if v1.tier > 0 then
        local v5 = LethalNum.multiply(LethalNum.multiply(LethalNum.pow(LethalNum.new(5, 0), v1.tier), LethalNum.new(5, 1)), t.SynthesisItems[v1.current].xpMulti)
        local v6 = t.GetSynLevelGoal(p1)

