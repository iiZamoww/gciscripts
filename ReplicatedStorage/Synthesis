    if v2 > 5 and v2 <= 15 then
        sum = v2 - 5
        v1 = Color3.new(1 - sum * 0.1, 1, 1 - sum * 0.1)
    else
        sum = v2
    end

    if v2 > 15 and v2 <= 25 then
        sum = sum - 15
        v1 = Color3.new(0, 1, 0.5 + sum * 0.05)
    end

    if v2 > 25 and v2 <= 35 then
        sum = sum - 25
        v1 = Color3.new(0 + sum * 0.05, 1 - sum * 0.1, 1)
    end

    if v2 > 35 and v2 <= 45 then
        sum = sum - 35
        v1 = Color3.new(0.5 + sum * 0.05, 0 + sum * 0.05, 1)
    end

    if v2 > 45 then
        v1 = Color3.new(1, 0.5 + (sum - 45) * 0.1, 1)
    end

    return v1
end
