    local current = v1.current
    local tier = v1.tier
    local level = v1.level
    local v2 = Multipliers.getMulti()

    if p2 then
        local v3 = p2.UpgradeLevels.synthesis[p1]

        current = v3.c

        local t2 = v3.t
        local l = v3.l

        v2 = p2.Multipliers
    end

    local v4 = LethalNum.new(1, 2)
    local v5 = 1

    if current == nil then
        current = "none"
    end

    if current ~= "none" then
        v5 = t.SynthesisItems[current].speedType or 1
    end

    if p2 then
        if p2.Stats.Accomplish.solTicks > 0 then
            v4 = LethalNum.multiply(v4, p2.Stats.Accomplish.solTickSpeed)
        end
    elseif Data.ImportantData.Stats.Accomplish.solTicks > 0 then
        v4 = LethalNum.multiply(v4, Data.ImportantData.Stats.Accomplish.solTickSpeed)
    end

    if v5 == 1 then
        local v8 = LethalNum.multiply(v4, v2.spdSyn)

        if p2 then
            return LethalNum.multiply(v8, p2.Temp.synSpd)
        end

        v4 = LethalNum.multiply(v8, Data.ImportantData.Stats.synSpd)
    end

    return v4
end
function t.GetSynMulti(p1, p2) --[[ GetSynMulti | Line: 209 | Upvalues: t (copy), Multipliers (copy), LethalNum (copy) ]]
    local v1 = t.SynthesisSlots[p1]
    local current = v1.current
    local tier = v1.tier
    local level = v1.level
    local v2 = Multipliers.getMulti()

    if p2 then
        local v3 = p2.UpgradeLevels.synthesis[p1]

        current = v3.c
        tier = v3.t
        level = v3.l
        v2 = p2.Multipliers
    end

    local v4 = LethalNum.new(0, 0)
    local v5 = LethalNum.new(5, 0)
    local v6

    if current == "none" then
        v6 = 1
    else
        v6 = t.SynthesisItems[current].multiType or 1
        v5 = t.SynthesisItems[current].baseMulti or LethalNum.new(5, 0)
    end

    if tier > 0 then
        local v9 = LethalNum.multiply(LethalNum.copy(v5), LethalNum.pow(LethalNum.new(5, 0), tier - 1))

        if v6 == 1 then
            v4 = if v2[current .. "Syn"] == nil then v9 else LethalNum.multiply(v9, v2[current .. "Syn"])

            if level > 0 then
                v4 = LethalNum.multiply(v4, LethalNum.pow(LethalNum.new(1.06, 0), level))
            end
        else
            v4 = v9
        end
