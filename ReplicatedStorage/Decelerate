        if Data.ImportantData.Stats.pDif > 0 then
            Resets.ResetPlanetTele()
        end

        if Data.ImportantData.Stats.realm == "decelerated" then
            t.decelerateWrapper()
        end

        if Data.ImportantData.Stats.realm == "recelerated" then
            t.recelerateWrapper()
        end

        ChangeVisual.ToEarth()
    end

    if p1 == "normal2" then
        if Data.ImportantData.Stats.pDif > 0 then
            Resets.ResetPlanetTele()
        end

        ChangeVisual.ToEarth()
    end

    if p1 == "normal3" then
        ChangeVisual.ToEarth()
    end

    if p1 == "space" then
        ChangeVisual.ToSpace()
    end

    if p1 == "anti" then
        if Data.ImportantData.Stats.pDif > 0 then
            Resets.ResetPlanetTele()
        end

        if Data.ImportantData.Stats.realm == "normal" then
            t.decelerateWrapper()
        end

        if Data.ImportantData.Stats.realm == "recelerated" then
            t.decelerateWrapper()
        end

        ChangeVisual.ToEarth()
    end

    if p1 == "unnatural" then
        if Data.ImportantData.Stats.pDif > 0 then
            Resets.ResetPlanetTele()
        end

        if Data.ImportantData.Stats.realm == "decelerated" then
            t.recelerateWrapper()
        end

        if Data.ImportantData.Stats.realm == "normal" then
            t.recelerateWrapper()
        end

        ChangeVisual.ToEarth()
    end

    if p1 ~= "planetoid" then
        return
    end

    if Data.ImportantData.Stats.pDif <= 0 then
        Resets.ResetPlanetTele()
    end

    ChangeVisual.ToEarth()
end

